# OasisBio OAuth Configuration
OASIS_OAUTH_CLIENT_ID=your-client-id-here
OASIS_OAUTH_CLIENT_SECRET=your-client-secret-here
OASIS_OAUTH_REDIRECT_URI=http://localhost:3001/auth/callback
OASIS_AUTH_URL=https://oasisbio.com/oauth/authorize
OASIS_TOKEN_URL=https://api.oasisbio.com/api/oauth/token
OASIS_USERINFO_URL=https://api.oasisbio.com/api/oauth/userinfo
OASIS_RESOURCES_URL=https://api.oasisbio.com/api/oauth/resources

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/muserock

# JWT Configuration
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=1h

# API Key Encryption (32-byte hex string, generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
API_KEY_ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# Application Configuration
PORT=3001
NODE_ENV=development

# Redis Configuration (for rate limiting)
REDIS_URL=redis://localhost:6379