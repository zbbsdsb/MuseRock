{
  "name": "muserock",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "cd apps/web && npm run dev",
    "build": "npm run build:web",
    "preview": "cd apps/web && npm run preview",
    "clean": "rm -rf apps/web/dist muserock-*.zip",
    "lint": "cd apps/web && npm run lint",
    "typecheck": "cd apps/web && npm run typecheck",
    "test": "cd apps/web && npm run test",
    "test:watch": "cd apps/web && npm run test:watch",
    "test:coverage": "cd apps/web && npm run test:coverage",
    "build:web": "cd apps/web && npm run build",
    "build:api": "cd apps/api && npm run build",
    "dev:api": "cd apps/api && npm run dev",
    "install:all": "npm install && cd apps/api && npm install && cd ../web && npm install",
    "release:build": "npm run typecheck && npm run build",
    "release:package": "node scripts/package-release.js",
    "release": "npm run release:build && npm run release:package"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^1.29.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.14",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "^11.17.0",
    "@vitejs/plugin-react": "^5.0.4",
    "docx": "^9.6.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.12.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "vite": "^6.2.0",
    "zustand": "^5.0.13",
    "openai": "^6.34.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-virtual": "^3.13.24",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/uuid": "^9.0.8",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.4.21",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.5",
    "uuid": "^9.0.1"
  }
}